#!/bin/bash
set -e

# Locate workspace: prefer env var, fall back to parent of this script's directory.
SCRIPT_DIR="$(cd "$(dirname "$(realpath "${BASH_SOURCE[0]}")")" && pwd)"
WORKSPACE_DIR="${WORKSPACE_DIR:-$(dirname "$SCRIPT_DIR")}"

# shellcheck source=common.sh
source "$WORKSPACE_DIR/scripts/common.sh"

# Request a mode transition via the /a2/set_mode service and report the FSM's
# accept/reject response. The FSM (see a2_utils/mode_fsm) only allows valid
# transitions, e.g. STAND_DOWN(1) -> STAND_UP(2) -> BALANCE_STAND(3) ->
# VELOCITY_MOVE(4). Returns 0 if the transition was accepted, 1 otherwise (so
# callers can chain stages and stop on the first rejection).
# NOTE: acceptance means the FSM took the transition, not that the robot has
# physically finished the motion.
_set_mode() {
    local mode="$1" out msg
    if ! out="$(ros2 service call /a2/set_mode a2_interfaces/srv/SetOperatingMode "{mode: $mode}" 2>&1)"; then
        error "Mode $mode: service call failed (is the locomotion controller running?)"
        echo "$out"
        return 1
    fi
    # The service reports a human-readable result, e.g. "Now in STAND_UP" or
    # "Cannot enter VELOCITY_MOVE from STAND_DOWN".
    msg="$(printf '%s' "$out" | grep -oP "message='\K[^']*" || true)"
    if printf '%s' "$out" | grep -q 'success=True'; then
        info "${msg:-Mode $mode accepted}"
        return 0
    fi
    error "${msg:-Mode $mode rejected}"
    return 1
}

_usage() {
    cat <<EOF
Usage: a2 <command> [options]

Workspace:
  source             Source the ROS/workspace environment (same as running a2)
  build [package] [-j N]  Build the workspace, or up to a specific package
                     (-j/--jobs sets parallel workers; default is half the cores)
  clean [--yes]      Remove build/install/log artifacts (--yes skips confirmation)
  env                Print key environment variables
  log                Tail the latest colcon build log

Robot:
  sim   [--rviz] [--dlio] [--headless] [--scene <file>]  Launch MuJoCo simulation
                     --headless runs with no MuJoCo viewer (visualize in RViz/Foxglove)
                     scenes: scene.xml (default), scene_flat.xml, scene_terrain.xml,
                             scene_obstacles.xml, scene_maze.xml, scene_test_meshes.xml
  walk               Command robot to walk    (mode=4)
  stop               Stop moving, keep balance (mode=3)
  unlock             Command robot to unlock  (mode=3)
  stand              Command robot to stand   (mode=2)
  sit                Command robot to sit     (mode=1)
  keyboard           Keyboard teleop -> /cmd_vel (robot must be in walk mode)
  nav   [--rviz]     Launch navigation stack
  explore [--rviz]   Launch autonomous exploration (TARE)
  dlio  [--rviz]     Launch DLIO LiDAR-inertial odometry
  detect             Launch object detection (YOLO, CPU); _real launch on robot

Introspection:
  topics             List active ROS topics
  nodes              List active ROS nodes

Data:
  bag record [-a] [-t topics] [-i ignore] [-c config.yaml] [suffix]
  bag play   <file> [--clock] [--pause]   Play back a rosbag (bag name resolves
                     against the bag dir; --clock publishes /clock, --pause starts paused)

Utilities:
  plotjuggler        Launch PlotJuggler
  foxglove           Launch Foxglove Bridge (default port 8765)
  router             Start Zenoh router (foreground)
  verify             Verify MuJoCo installation

Mode:      ${A2_MODE:-unknown}
Workspace: $WORKSPACE_DIR
EOF
}

# Separate flags from positional args
RVIZ=false
DLIO=false
HEADLESS=false
YES=false
SCENE=""
JOBS=""
ARGS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --rviz) RVIZ=true; shift ;;
        --dlio) DLIO=true; shift ;;
        --headless) HEADLESS=true; shift ;;
        --yes)  YES=true; shift ;;
        -j|--jobs)
            if [[ -z "${2:-}" ]]; then error "$1 requires a value (e.g. -j 8)"; exit 1; fi
            JOBS="$2"; shift 2 ;;
        -j=*|--jobs=*) JOBS="${1#*=}"; shift ;;
        --scene)
            if [[ -z "${2:-}" ]]; then error "--scene requires a value (e.g. scene_maze.xml)"; exit 1; fi
            SCENE="$2"; shift 2 ;;
        --scene=*) SCENE="${1#*=}"; shift ;;
        *)      ARGS+=("$1"); shift ;;
    esac
done

CMD="${ARGS[0]:-}"

case "$CMD" in
    source)
        # Sourcing must happen in the calling shell, not a subprocess.
        # This is handled by the a2() function in .bashrc — if you see this
        # message, you called the binary directly instead of via the function.
        error "Cannot source from a subprocess. Use the shell function:"
        error "  Add 'a2() { ... }' to your shell (see environment/shell/.bashrc)"
        exit 1
        ;;
    build)
        # -j/--jobs overrides the worker count; build_workspace.sh reads A2_BUILD_JOBS.
        (cd "$WORKSPACE_DIR" && A2_BUILD_JOBS="${JOBS:-$A2_BUILD_JOBS}" bash scripts/build_workspace.sh "${ARGS[1]:-}")
        ;;
    clean)
        if $YES; then
            echo y | (cd "$WORKSPACE_DIR" && bash scripts/clean_workspace.sh)
        else
            (cd "$WORKSPACE_DIR" && bash scripts/clean_workspace.sh)
        fi
        ;;
    env)
        info "A2_MODE              = ${A2_MODE:-<unset>}"
        info "RMW_IMPLEMENTATION   = ${RMW_IMPLEMENTATION:-<unset>}"
        info "ROS_DOMAIN_ID        = ${ROS_DOMAIN_ID:-<unset>}"
        info "ZENOH_ROUTER_IP      = ${ZENOH_ROUTER_IP:-<unset>}"
        info "ZENOH_ROUTER_IP_SIM  = ${ZENOH_ROUTER_IP_SIM:-<unset>}"
        info "ZENOH_ROUTER_IP_ROBOT= ${ZENOH_ROUTER_IP_ROBOT:-<unset>}"
        info "MUJOCO_DIR           = ${MUJOCO_DIR:-<unset>}"
        info "ROS_BAGS_DIR         = ${ROS_BAGS_DIR:-<unset>}"
        info "WORKSPACE_DIR        = $WORKSPACE_DIR"
        ;;
    log)
        LOG_DIR="${A2_WS_ROOT:-$WORKSPACE_DIR}/log"
        LATEST=$(find "$LOG_DIR" -name "*.log" 2>/dev/null | sort -t/ -k1 | tail -1)
        if [[ -z "$LATEST" ]]; then
            error "No build logs found in $LOG_DIR"
            exit 1
        fi
        info "Tailing: $LATEST"
        tail -f "$LATEST"
        ;;
    sim)
        SIM_ARGS=(rviz:=$RVIZ dlio:=$DLIO headless:=$HEADLESS)
        [ -n "$SCENE" ] && SIM_ARGS+=(scene:="$SCENE")
        ros2 launch a2_ros sim.launch.py "${SIM_ARGS[@]}"
        ;;
    walk)
        _set_mode 4
        ;;
    stop)
        _set_mode 3
        ;;
    unlock)
        _set_mode 3
        ;;
    stand)
        _set_mode 2
        ;;
    sit)
        _set_mode 1
        ;;
    keyboard)
        # Keyboard teleop -> twist_mux's key_vel input (prio 90), which the mux
        # forwards to /cmd_vel. The stack expects TwistStamped, so publish stamped;
        # in sim align timestamps with /clock so they aren't dropped as stale.
        # Robot must already be in walk mode (a2 walk) to actually move.
        KB_ARGS=(-p stamped:=true -r cmd_vel:=/key_vel)
        [ "$A2_MODE" = "sim" ] && KB_ARGS+=(-p use_sim_time:=true)
        ros2 run teleop_twist_keyboard teleop_twist_keyboard --ros-args "${KB_ARGS[@]}"
        ;;
    nav)
        ros2 launch a2_ros navigation.launch.py rviz:=$RVIZ
        ;;
    explore)
        ros2 launch a2_ros exploration.launch.py rviz:=$RVIZ
        ;;
    dlio)
        DLIO_ARGS=(rviz:=$RVIZ)
        [ "$A2_MODE" = "sim" ] && DLIO_ARGS+=(use_sim_time:=true)
        ros2 launch a2_ros dlio.launch.py "${DLIO_ARGS[@]}"
        ;;
    detect)
        # Object detection (YOLO, runs on CPU). Use the real-robot launch on hardware.
        if [ "$A2_MODE" = "robot" ]; then
            ros2 launch object_detection object_detection_real.launch.py
        else
            ros2 launch object_detection object_detection.launch.py
        fi
        ;;
    topics)
        ros2 topic list
        ;;
    nodes)
        ros2 node list
        ;;
    bag)
        SUBCMD="${ARGS[1]:-}"
        case "$SUBCMD" in
            record)
                # Pass all remaining args through to record.sh
                bash "$WORKSPACE_DIR/scripts/record.sh" "${ARGS[@]:2}"
                ;;
            play)
                FILE="${ARGS[2]:-}"
                if [[ -z "$FILE" ]]; then
                    error "Usage: a2 bag play <file> [--clock] [--pause]"
                    exit 1
                fi
                # Resolve relative to the bag directory (same default as
                # `a2 bag record`) so you can pass just the bag name; fall back
                # to the path as given.
                BAG_DIR="${ROS_BAGS_DIR:-${A2_WS_ROOT:-$WORKSPACE_DIR}/bags}"
                if [[ ! -e "$FILE" && -e "$BAG_DIR/$FILE" ]]; then
                    FILE="$BAG_DIR/$FILE"
                fi
                # Pass through any extra args, e.g. --clock (publish /clock) and
                # --pause (start paused), straight to ros2 bag play.
                ros2 bag play "$FILE" "${ARGS[@]:3}"
                ;;
            *)
                error "Usage: a2 bag record [OPTIONS] [SUFFIX] | a2 bag play <file>"
                info  "  a2 bag record --help  for recording options"
                exit 1
                ;;
        esac
        ;;
    plotjuggler)
        ros2 run plotjuggler plotjuggler
        ;;
    foxglove)
        # In sim, align the bridge's clock with the simulator (/clock); on the
        # real robot leave it on wall-clock time.
        FOXGLOVE_ARGS=(port:=8765)
        [ "$A2_MODE" = "sim" ] && FOXGLOVE_ARGS+=(use_sim_time:=true)
        ros2 launch foxglove_bridge foxglove_bridge_launch.xml "${FOXGLOVE_ARGS[@]}"
        ;;
    router)
        bash "$WORKSPACE_DIR/scripts/start_zenoh_router.sh"
        ;;
    verify)
        bash "$WORKSPACE_DIR/scripts/verify_mujoco.sh"
        ;;
    "" | help)
        _usage
        ;;
    *)
        error "Unknown command: $CMD"
        echo
        _usage
        exit 1
        ;;
esac
